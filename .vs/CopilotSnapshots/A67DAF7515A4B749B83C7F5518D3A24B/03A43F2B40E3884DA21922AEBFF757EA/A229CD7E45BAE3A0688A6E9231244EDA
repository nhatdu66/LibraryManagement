<Window x:Class="LibraryManagementSystem.WPF.Views.DetailBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Book Detail" Height="420" Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Title:" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBlock x:Name="tbTitle" Grid.Row="0" Grid.Column="1" Margin="6" TextWrapping="Wrap"/>

        <TextBlock Text="Authors:" Grid.Row="1" VerticalAlignment="Center"/>
        <TextBlock x:Name="tbAuthors" Grid.Row="1" Grid.Column="1" Margin="6" TextWrapping="Wrap"/>

        <TextBlock Text="Categories:" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBlock x:Name="tbCategories" Grid.Row="2" Grid.Column="1" Margin="6" TextWrapping="Wrap"/>

        <TextBlock Text="First Publish Year:" Grid.Row="3" VerticalAlignment="Center"/>
        <TextBlock x:Name="tbYear" Grid.Row="3" Grid.Column="1" Margin="6"/>

        <TextBlock Text="Summary:" Grid.Row="4" VerticalAlignment="Top"/>
        <TextBox x:Name="tbSummary" Grid.Row="4" Grid.Column="1" Margin="6" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Width="90" Margin="6" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>