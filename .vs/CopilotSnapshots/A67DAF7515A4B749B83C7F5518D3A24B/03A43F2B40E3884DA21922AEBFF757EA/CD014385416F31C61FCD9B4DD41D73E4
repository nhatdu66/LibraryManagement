<Window x:Class="LibraryManagementSystem.WPF.Views.EditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Book" Height="520" Width="640"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Title:" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtTitle" Grid.Row="0" Grid.Column="1" Margin="6"/>

        <TextBlock Text="Original Title:" Grid.Row="1" VerticalAlignment="Center"/>
        <TextBox x:Name="txtOriginalTitle" Grid.Row="1" Grid.Column="1" Margin="6"/>

        <TextBlock Text="Summary:" Grid.Row="2" VerticalAlignment="Top"/>
        <TextBox x:Name="txtSummary" Grid.Row="2" Grid.Column="1" Margin="6" Height="100" AcceptsReturn="True" TextWrapping="Wrap"/>

        <TextBlock Text="First Publish Year:" Grid.Row="3" VerticalAlignment="Center"/>
        <TextBox x:Name="txtYear" Grid.Row="3" Grid.Column="1" Margin="6"/>

        <TextBlock Text="Series:" Grid.Row="4" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbSeries" Grid.Row="4" Grid.Column="1" Margin="6" DisplayMemberPath="SeriesName" SelectedValuePath="SeriesId"/>

        <TextBlock Text="Author:" Grid.Row="5" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="6">
            <ComboBox x:Name="cbAuthor" Width="320" DisplayMemberPath="AuthorName" SelectedValuePath="AuthorId"/>
            <Button Content="Add Author" Width="90" Margin="8,0,0,0" Click="btnAddAuthor_Click"/>
        </StackPanel>

        <TextBlock Text="Category:" Grid.Row="6" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="6" Grid.Column="1" Margin="6">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox x:Name="txtNewCategory" Width="260" Height="26"/>
                <Button Content="Add Category" Width="100" Margin="8,0,0,0" Click="btnAddCategory_Click"/>
            </StackPanel>
            <ListBox x:Name="lbCategory" Height="140" SelectionMode="Multiple">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="6">
            <Button Content="Save" Width="100" Margin="6" Click="btnSave_Click"/>
            <Button Content="Cancel" Width="100" Margin="6" Click="btnCancel_Click"/>
        </StackPanel>

    </Grid>
</Window>