<Application x:Class="LibraryManagementSystem.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<!-- Quan trọng: trỏ đến MainWindow.xaml -->
	<Application.Resources>
		<!-- Nếu có Resource chung (Style, Brush) thì đặt ở đây -->
		<!-- Trong App.xaml hoặc ResourceDictionary -->
		<Style x:Key="CenterText" TargetType="TextBlock">
			<Setter Property="TextAlignment" Value="Center"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>
	</Application.Resources>
</Application>
