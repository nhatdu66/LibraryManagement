<Window x:Class="LibraryManagementSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LibraryManagementSystem.WPF.Views"
        Title="Quản Lý Thư Viện" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Text="Quản Lý Thư Viện" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>

		<TabControl x:Name="tabMain" Grid.Row="1" Margin="0,10,0,0">
			<TabItem Header="Đăng nhập">
				<views:LoginView />
			</TabItem>

			<TabItem Header="Danh sách sách">
				<views:BookCatalogView />
			</TabItem>

			<TabItem Header="Mượn Sách" IsEnabled="False">
				<TextBlock Text="Chức năng đang phát triển" Margin="30" FontSize="14"/>
			</TabItem>

			<TabItem Header="Tài khoản" IsEnabled="False">
				<TextBlock Text="Chức năng đang phát triển" Margin="30" FontSize="14"/>
			</TabItem>
		</TabControl>
	</Grid>
</Window>