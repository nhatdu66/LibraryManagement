<Window x:Class="LibraryManagementSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LibraryManagementSystem.WPF.Views"
        Title="Quản Lý Thư Viện" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header (giữ nguyên nếu có) -->
		<TextBlock Grid.Row="0" Text="Quản lý Thư viện" FontSize="20" Margin="0,0,0,10"/>

		<TabControl Grid.Row="1">
			<!-- Tab Đăng nhập -->
			<TabItem Header="Đăng nhập">
				<views:LoginView />
			</TabItem>

			<!-- Tab Danh sách sách -->
			<TabItem Header="Danh sách sách">
				<views:BookCatalogView />
			</TabItem>

			<!-- Tab còn lại giữ nguyên placeholder -->
			<TabItem Header="Mượn Sách" IsEnabled="False">
				<TextBlock Text="Chức năng đang phát triển" Margin="30" FontSize="14"/>
			</TabItem>

			<TabItem Header="Tài khoản" IsEnabled="False">
				<TextBlock Text="Chức năng đang phát triển" Margin="30" FontSize="14"/>
			</TabItem>
		</TabControl>
	</Grid>
</Window>