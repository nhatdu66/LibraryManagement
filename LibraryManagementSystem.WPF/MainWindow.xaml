<Window x:Class="LibraryManagementSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LibraryManagementSystem.WPF.Views"
        Title="Quản Lý Thư Viện" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

	<!-- Quan trọng: trỏ đến MainWindow.xaml -->
	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
	</Window.Resources>

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
			<TextBlock Text="{Binding WelcomeMessage}" FontWeight="Bold" Margin="0,0,5,0"/>
			<TextBlock Text="{Binding RoleDisplay}" 
               FontWeight="Medium" 
               FontSize="13" 
               Foreground="#2C3E50"
               Margin="0,0,5,0"/>
			<Button Content="Đăng xuất" Command="{Binding LogoutCommand}" 
                    Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}" 
                    Width="100" Height="32"/>
		</StackPanel>

		<TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">

			<TabItem Header="Đăng nhập">
				<views:LoginView DataContext="{Binding LoginVM}"/>
			</TabItem>

			<TabItem Header="Danh sách sách">
				<views:BookCatalogView />
			</TabItem>

			<!-- Tab 3: Quản lý sách -->
			<TabItem Header="Quản lý sách"
				IsEnabled="{Binding CanManageBooks}"
				Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
				<views:ManageBooksView DataContext="{Binding ManageBooksVM}"/>
			</TabItem>

			<!-- Tab 4: Quản lý mượn sách -->
			<TabItem Header="Quản lý mượn sách"
             IsEnabled="{Binding CanManageBorrow}"
             Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
				<views:BorrowView DataContext="{Binding BorrowVM}"/>
			</TabItem>

			<!-- Tab 5: Tài khoản cá nhân -->
			<TabItem Header="Tài khoản cá nhân"
             IsEnabled="{Binding IsLoggedIn}"
             Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
				<views:MyAccountView DataContext="{Binding MyAccountVM}"/>
			</TabItem>

			<!-- Tab 6: Quản lý tài khoản (chỉ Admin) -->
			<TabItem Header="Quản lý tài khoản"
             IsEnabled="{Binding CanManageAccounts}"
             Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
				<views:ManageAccountsView DataContext="{Binding ManageAccountsVM}"/>
			</TabItem>

		</TabControl>
	</Grid>
</Window>
