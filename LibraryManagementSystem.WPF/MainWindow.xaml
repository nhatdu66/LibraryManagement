<Window x:Class="LibraryManagementSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Thư Viện" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Header -->
			<RowDefinition Height="*"/>
			<!-- Nội dung chính -->
		</Grid.RowDefinitions>

		<!-- Header đơn giản -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
			<TextBlock Text="Quản Lý Thư Viện" FontSize="18" FontWeight="Bold"/>
			<TextBlock x:Name="txtUserInfo" Text="Chưa đăng nhập" Margin="30,0,0,0" VerticalAlignment="Center" FontSize="14"/>

			<!-- Nút Đăng xuất (ẩn ban đầu, hiện khi đã login) -->
			<Button x:Name="btnLogout" Content="Đăng xuất" Width="90" Height="28" Margin="20,0,0,0" 
            Visibility="Collapsed" Click="BtnLogout_Click"/>
		</StackPanel>

		<!-- TabControl -->
		<TabControl x:Name="tabControl" Grid.Row="1">

			<!-- Tab 0: Đăng Nhập -->
			<TabItem Header="Đăng Nhập">
				<StackPanel Margin="30">
					<TextBlock Text="Email" Margin="0,8,0,4" FontSize="14"/>
					<TextBox x:Name="txtEmail" Width="320" HorizontalAlignment="Left" Height="28"/>

					<TextBlock Text="Mật khẩu" Margin="0,12,0,4" FontSize="14"/>
					<PasswordBox x:Name="txtPassword" Width="320" HorizontalAlignment="Left" Height="28"/>

					<Button Content="Đăng Nhập" Width="110" Margin="0,20,0,0" 
                            HorizontalAlignment="Left" Height="32" Click="BtnLogin_Click"/>

					<TextBlock x:Name="txtLoginStatus" Text="" Margin="0,12,0,0" Foreground="Red" FontSize="13"/>
				</StackPanel>
			</TabItem>

			<!-- Tab 1: Danh Sách Sách -->
			<TabItem Header="Danh Sách Sách" IsEnabled="False">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,8">
						<TextBox x:Name="txtSearch" Width="320" Height="28" TextChanged="TxtSearch_TextChanged"/>
						<Button Content="Tìm kiếm" Width="90" Margin="10,0,0,0" Click="BtnSearch_Click"/>
					</StackPanel>

					<ListView x:Name="lvBooks" Grid.Row="1">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Tên sách" DisplayMemberBinding="{Binding Title}" Width="320"/>
								<GridViewColumn Header="Tác giả" DisplayMemberBinding="{Binding Authors}" Width="220"/>
								<GridViewColumn Header="Thể loại" DisplayMemberBinding="{Binding Categories}" Width="200"/>
								<GridViewColumn Header="Còn lại" DisplayMemberBinding="{Binding AvailableCopies}" Width="90"/>
								<GridViewColumn Header="Tổng" DisplayMemberBinding="{Binding TotalCopies}" Width="80"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</TabItem>

			<!-- Tab 2 & 3: Tạm disable -->
			<TabItem Header="Mượn Sách" IsEnabled="False">
				<TextBlock Text="Chức năng đang phát triển" Margin="30" FontSize="14"/>
			</TabItem>
			<TabItem Header="Tài Khoản" IsEnabled="False">
				<TextBlock Text="Chức năng đang phát triển" Margin="30" FontSize="14"/>
			</TabItem>
		</TabControl>
	</Grid>
</Window>