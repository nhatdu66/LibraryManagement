<Window x:Class="LibraryManagementSystem.WPF.Views.CreateBorrowTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:LibraryManagementSystem.WPF.Helpers"
        mc:Ignorable="d"
        Title="Tạo giao dịch mượn mới" Height="800" Width="1100"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="6*"/>
			<RowDefinition Height="4*"/>
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="0,0,0,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="*"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<GroupBox Grid.Row="0" Grid.Column="0" Header="1. Độc giả" Margin="0,0,6,6">
				<Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox Grid.Column="0" Text="{Binding SearchReaderKeyword}" Padding="6" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
						<Button Grid.Column="1" Content="Tìm kiếm" Width="80" Command="{Binding SearchReaderCmd}"/>
					</Grid>

					<ListView Grid.Row="1" ItemsSource="{Binding ReaderResults}" SelectedItem="{Binding SelectedReader}">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Họ tên" DisplayMemberBinding="{Binding FullName}" Width="180"/>
								<GridViewColumn Header="Mã thẻ" DisplayMemberBinding="{Binding CardNumber}" Width="110"/>
								<GridViewColumn Header="Trạng thái" DisplayMemberBinding="{Binding ReaderStatus}" Width="90"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</GroupBox>

			<GroupBox Grid.Row="0" Grid.Column="1" Header="2. Tác phẩm (Work)" Margin="6,0,0,6">
				<Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox Grid.Column="0" Text="{Binding SearchWorkKeyword}" Padding="6" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
						<Button Grid.Column="1" Content="Tìm kiếm" Width="80" Command="{Binding SearchWorkCmd}"/>
					</Grid>

					<ListView Grid.Row="1" ItemsSource="{Binding WorkResults}" SelectedItem="{Binding SelectedWork}">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Tên sách" DisplayMemberBinding="{Binding Title}" Width="220"/>
								<GridViewColumn Header="Tác giả" DisplayMemberBinding="{Binding AuthorsString}" Width="140"/>
								<GridViewColumn Header="Còn lại" DisplayMemberBinding="{Binding AvailableCopies}" Width="60"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</GroupBox>

			<GroupBox Grid.Row="1" Grid.Column="0" Header="3. Phiên bản (Edition)" Margin="0,6,6,0">
				<Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox Grid.Column="0" Text="{Binding SearchEditionKeyword}" Padding="6" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
						<Button Grid.Column="1" Content="Tìm kiếm" Width="80" Command="{Binding SearchEditionCmd}"/>
					</Grid>

					<ListView Grid.Row="1" ItemsSource="{Binding EditionResults}" SelectedItem="{Binding SelectedEdition}">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Nhà XB" DisplayMemberBinding="{Binding PublisherName}" Width="140"/>
								<GridViewColumn Header="Năm XB" DisplayMemberBinding="{Binding PublishYear}" Width="70"/>
								<GridViewColumn Header="ISBN" DisplayMemberBinding="{Binding ISBN}" Width="120"/>
								<GridViewColumn Header="Còn" DisplayMemberBinding="{Binding AvailableCopies}" Width="60"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</GroupBox>

			<GroupBox Grid.Row="1" Grid.Column="1" Header="4. Bản sao khả dụng (Copy)" Margin="6,6,0,0">
				<Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox Grid.Column="0" Text="{Binding SearchCopyKeyword}" Padding="6" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
						<Button Grid.Column="1" Content="Tìm kiếm" Width="80" Command="{Binding SearchCopyCmd}"/>
					</Grid>

					<ListView Grid.Row="1" ItemsSource="{Binding CopyResults}" SelectedItem="{Binding SelectedCopy}">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Copy ID" DisplayMemberBinding="{Binding CopyId}" Width="70"/>
								<GridViewColumn Header="Barcode" DisplayMemberBinding="{Binding Barcode}" Width="120"/>
								<GridViewColumn Header="Kệ" DisplayMemberBinding="{Binding ShelfLocation}" Width="80"/>
								<GridViewColumn Header="Tình trạng" DisplayMemberBinding="{Binding PhysicalCondition}" Width="100"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</GroupBox>
		</Grid>

		<Grid Grid.Row="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<Grid Grid.Row="0" Margin="0,0,0,8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<Button Grid.Column="0" Content="⬇ Thêm bản sao đang chọn vào danh sách" Height="36" Padding="15,0"
                        Command="{Binding AddCopyCmd}" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Cursor="Hand"/>

				<TextBlock Grid.Column="1" Text="{Binding SelectedReader.FullName, StringFormat='👤 Độc giả: {0}'}" 
                           VerticalAlignment="Center" Margin="20,0,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#1976D2"/>
			</Grid>

			<DataGrid Grid.Row="1" ItemsSource="{Binding BorrowDetails}" AutoGenerateColumns="False" CanUserAddRows="False" 
                      IsReadOnly="True" ScrollViewer.VerticalScrollBarVisibility="Auto">
				<DataGrid.Columns>
					<DataGridTextColumn Header="Tên sách" Binding="{Binding Title}" Width="*"/>
					<DataGridTextColumn Header="Phiên bản" Binding="{Binding EditionInfo}" Width="220"/>
					<DataGridTextColumn Header="Copy ID" Binding="{Binding CopyId}" Width="90"/>
					<DataGridTextColumn Header="Kệ" Binding="{Binding ShelfLocation}" Width="100"/>
					<DataGridTextColumn Header="Hạn trả" Binding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="110"/>
				</DataGrid.Columns>
			</DataGrid>

			<Grid Grid.Row="2" Margin="0,12,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="Ngày mượn:" VerticalAlignment="Center" Margin="0,0,8,0"/>
					<DatePicker SelectedDate="{Binding BorrowDate}" Width="120" IsEnabled="False" VerticalAlignment="Center"/>

					<TextBlock Text="Thời hạn (ngày):" VerticalAlignment="Center" Margin="20,0,8,0"/>
					<TextBox Text="{Binding DurationDays}" Width="60" Padding="6" VerticalContentAlignment="Center"/>

					<TextBlock Text="{Binding StatusMessage}" Foreground="#D32F2F" FontWeight="Medium" TextWrapping="Wrap" Margin="20,0,0,0" VerticalAlignment="Center"/>
				</StackPanel>

				<StackPanel Grid.Column="1" Orientation="Horizontal">
					<Button Content="Hủy" Width="100" Height="38" Click="CancelButton_Click" Margin="0,0,10,0"/>
					<Button Content="💾 Lưu giao dịch" Width="140" Height="38" 
                            Command="{Binding SaveTransactionCmd}" 
                            Background="#2196F3" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
				</StackPanel>
			</Grid>
		</Grid>
	</Grid>
</Window>