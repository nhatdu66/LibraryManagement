<UserControl x:Class="LibraryManagementSystem.WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">

	<Grid Margin="30">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Tiêu đề -->
			<RowDefinition Height="Auto"/>
			<!-- Chọn loại tài khoản -->
			<RowDefinition Height="Auto"/>
			<!-- Label Email -->
			<RowDefinition Height="Auto"/>
			<!-- Ô Email -->
			<RowDefinition Height="Auto"/>
			<!-- Label Mật khẩu -->
			<RowDefinition Height="Auto"/>
			<!-- Ô Mật khẩu -->
			<RowDefinition Height="Auto"/>
			<!-- Nút Đăng nhập -->
			<RowDefinition Height="*"/>
			<!-- Status message -->
		</Grid.RowDefinitions>

		<!-- 0: Tiêu đề -->
		<TextBlock Grid.Row="0"
                   Text="Đăng nhập hệ thống"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

		<!-- 1: Chọn loại tài khoản -->
		<StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">
			<RadioButton x:Name="rbReader"
                         Content="Bạn đọc (Reader)"
                         GroupName="AccountType"
                         IsChecked="True"
                         Checked="rbAccountType_Checked"
                         Margin="0,0,40,0"/>
			<RadioButton x:Name="rbEmployee"
                         Content="Nhân viên (Employee)"
                         GroupName="AccountType"
                         Checked="rbAccountType_Checked"/>
		</StackPanel>

		<!-- 2: Label Email -->
		<TextBlock Grid.Row="2"
                   Text="Email:"
                   Margin="0,0,0,5"
                   HorizontalAlignment="Left"/>

		<!-- 3: Ô nhập Email -->
		<TextBox Grid.Row="3"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                 Width="300"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,10"/>

		<!-- 4: Label Mật khẩu -->
		<TextBlock Grid.Row="4"
                   Text="Mật khẩu:"
                   Margin="0,0,0,5"
                   HorizontalAlignment="Left"/>

		<!-- 5: Ô nhập Mật khẩu (đúng thứ tự, nằm dưới email) -->
		<PasswordBox x:Name="txtPassword"
                     Grid.Row="5"
                     Width="300"
                     HorizontalAlignment="Left"
                     PasswordChanged="txtPassword_PasswordChanged"
                     Margin="0,0,0,15"/>

		<!-- 6: Nút Đăng nhập -->
		<Button Grid.Row="6"
                Content="Đăng nhập"
                Command="{Binding LoginCommand}"
                Width="120"
                Height="35"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"/>

		<!-- 7: Thông báo trạng thái (dưới cùng) -->
		<TextBlock Grid.Row="7"
                   Text="{Binding StatusMessage}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Left"/>
	</Grid>
</UserControl>