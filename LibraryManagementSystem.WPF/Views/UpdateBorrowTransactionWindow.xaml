<Window x:Class="LibraryManagementSystem.WPF.Views.UpdateBorrowTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chỉnh sửa giao dịch mượn" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Thông tin giao dịch -->
		<StackPanel Grid.Row="0" Margin="0,0,0,15">
			<TextBlock Text="{Binding BorrowId, StringFormat='Giao dịch #{0}'}" FontSize="18" FontWeight="Bold"/>
			<TextBlock Text="{Binding Transaction.ReaderFullName, StringFormat='Độc giả: {0}'}" FontSize="14"/>
		</StackPanel>

		<!-- DataGrid editable -->
		<DataGrid Grid.Row="1" ItemsSource="{Binding EditableDetails}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False">

			<DataGrid.Columns>
				<DataGridTextColumn Header="Tên sách" Binding="{Binding Title}" Width="*" IsReadOnly="True"/>
				<DataGridTextColumn Header="Copy ID" Binding="{Binding CopyId}" Width="80" IsReadOnly="True"/>

				<!-- Hạn trả - DatePicker editable -->
				<DataGridTemplateColumn Header="Hạn trả" Width="140">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<DatePicker SelectedDate="{Binding DueDate, Mode=TwoWay}" 
                                        Width="130" HorizontalAlignment="Left"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

				<!-- Trạng thái - editable -->
				<DataGridTextColumn Header="Trạng thái sách" Binding="{Binding ItemStatus}" Width="120"/>
			</DataGrid.Columns>
		</DataGrid>

		<!-- Footer -->
		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
			<Button Content="Hủy" Width="100" Height="38" Margin="0,0,12,0" Click="CancelButton_Click"/>
			<Button Content="💾 Lưu thay đổi" Width="140" Height="38" 
                    Command="{Binding SaveCommand}" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold"/>
		</StackPanel>
	</Grid>
</Window>