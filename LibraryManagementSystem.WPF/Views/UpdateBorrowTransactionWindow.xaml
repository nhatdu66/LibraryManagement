<Window x:Class="LibraryManagementSystem.WPF.Views.UpdateBorrowTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gia hạn / Cập nhật giao dịch mượn" Height="280" Width="450"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="20">
		<StackPanel>
			<TextBlock Text="{Binding BorrowId, StringFormat='Giao dịch #{0}'}" 
                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

			<TextBlock Text="Số ngày gia hạn thêm (áp dụng cho sách chưa trả):" 
                       Margin="0,0,0,8" FontWeight="Medium"/>

			<TextBox Text="{Binding AdditionalDays}" Width="120" HorizontalAlignment="Left" 
                     Padding="8" FontSize="14"/>

			<TextBlock Text="{Binding StatusMessage}" Foreground="#D32F2F" 
                       Margin="0,15,0,0" TextWrapping="Wrap"/>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
				<Button Content="Hủy" Width="100" Height="38" Margin="0,0,12,0" 
                        Click="CancelButton_Click"/>
				<Button Content="💾 Lưu gia hạn" Width="140" Height="38" 
                        Command="{Binding SaveCommand}" 
                        Background="#2196F3" Foreground="White" FontWeight="Bold"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</Window>